{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://demiengine.local/schemas/project.schema.json",
  "title": "DemiEngine Project",
  "type": "object",
  "required": ["format_version", "name", "scenes"],
  "additionalProperties": true,
  "properties": {
    "format_version": {
      "type": "integer",
      "minimum": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "main_scene": {
      "type": "string",
      "pattern": "^scene://"
    },
    "input": {
      "type": "object",
      "properties": {
        "actions": {
          "type": "object",
          "additionalProperties": {
            "oneOf": [
              {"$ref": "#/$defs/input_bindings"},
              {
                "type": "object",
                "required": ["bindings"],
                "properties": {
                  "bindings": {"$ref": "#/$defs/input_bindings"}
                }
              }
            ]
          }
        }
      }
    },
    "physics": {
      "type": "object",
      "properties": {
        "layers": {
          "type": "object",
          "maxProperties": 16,
          "additionalProperties": {
            "type": "array",
            "uniqueItems": true,
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "simulation": {
      "type": "object",
      "properties": {
        "fixed_timestep": {
          "type": "number",
          "minimum": 0.001,
          "maximum": 1.0,
          "default": 0.016666667
        },
        "random_seed": {
          "type": "integer",
          "minimum": 1,
          "default": 1
        }
      }
    },
    "debug": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "colliders": { "type": "boolean", "default": false },
        "contacts": { "type": "boolean", "default": false },
        "grid": { "type": "boolean", "default": false },
        "entity_ids": { "type": "boolean", "default": false },
        "draw_order": { "type": "boolean", "default": false },
        "ui_bounds": { "type": "boolean", "default": false },
        "profiler_hud": { "type": "boolean", "default": false }
      }
    },
    "scenes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "path"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^scene://"
          },
          "path": {
            "type": "string"
          }
        }
      }
    },
    "scripting": {
      "type": "object",
      "properties": {
        "language": { "type": "string" },
        "entry": { "type": "string", "pattern": "^script://" },
        "modules": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "input_bindings": {
      "type": "array",
      "items": {
        "oneOf": [
          {"type": "string"},
          {
            "type": "object",
            "required": ["input"],
            "properties": {
              "input": {"type": "string"},
              "scale": {"type": "number", "minimum": -1, "maximum": 1}
            }
          }
        ]
      }
    }
  }
}
