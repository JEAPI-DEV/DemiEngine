{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://demiengine.local/schemas/project.schema.json",
  "title": "DemiEngine Project",
  "type": "object",
  "required": ["format_version", "name", "scenes"],
  "additionalProperties": true,
  "properties": {
    "format_version": {
      "type": "integer",
      "minimum": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "main_scene": {
      "type": "string",
      "pattern": "^scene://"
    },
    "scenes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "path"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^scene://"
          },
          "path": {
            "type": "string"
          }
        }
      }
    },
    "scripting": {
      "type": "object",
      "properties": {
        "language": { "type": "string" },
        "entry": { "type": "string", "pattern": "^script://" },
        "modules": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
