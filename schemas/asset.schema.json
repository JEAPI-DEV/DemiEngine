{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://demiengine.local/schemas/asset.schema.json",
  "title": "DemiEngine Asset Manifest",
  "type": "object",
  "required": ["format_version", "id", "type", "source"],
  "additionalProperties": true,
  "properties": {
    "format_version": {
      "type": "integer",
      "minimum": 1
    },
    "id": {
      "type": "string",
      "pattern": "^asset://"
    },
    "type": {
      "type": "string",
      "enum": ["Texture2D", "Model3D", "AudioClip", "VideoClip"]
    },
    "source": {
      "type": "string"
    },
    "texture": {
      "type": "string"
    },
    "atlas": {
      "type": "string"
    },
    "settings": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "filter": {
          "type": "string",
          "enum": ["nearest", "bilinear", "trilinear"]
        },
        "wrap": {
          "type": "string",
          "enum": ["repeat", "clamp", "mirror"]
        },
        "mipmaps": {
          "type": "boolean"
        }
      }
    }
  }
}
