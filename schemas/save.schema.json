{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://demiengine.local/schemas/save.schema.json",
  "title": "DemiEngine Save",
  "type": "object",
  "required": ["format_version", "slot", "state"],
  "additionalProperties": true,
  "properties": {
    "format_version": {
      "type": "integer",
      "minimum": 1,
      "default": 2
    },
    "slot": {
      "type": "string",
      "minLength": 1
    },
    "project": {
      "type": "string"
    },
    "state_model": {
      "type": "string",
      "enum": ["game_state_v1"]
    },
    "metadata": {
      "type": "object",
      "required": ["autosave", "sequence", "reason"],
      "additionalProperties": true,
      "properties": {
        "autosave": { "type": "boolean" },
        "sequence": { "type": "integer", "minimum": 0 },
        "reason": { "type": "string" }
      }
    },
    "state": {
      "type": "object"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "state_model": { "const": "game_state_v1" } },
        "required": ["state_model"]
      },
      "then": {
        "required": ["metadata"],
        "properties": {
          "state": {
            "required": ["game", "selected_entities", "prefab_instances", "lua"],
            "properties": {
              "game": { "type": "object" },
              "selected_entities": { "type": "object" },
              "prefab_instances": { "type": "object" },
              "lua": { "type": "object" }
            }
          }
        }
      }
    }
  ]
}
