{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://demiengine.local/schemas/scene.schema.json",
  "title": "DemiEngine Scene",
  "type": "object",
  "required": ["format_version", "id", "entities"],
  "additionalProperties": true,
  "properties": {
    "format_version": {
      "type": "integer",
      "minimum": 1
    },
    "id": {
      "type": "string",
      "pattern": "^scene://"
    },
    "name": {
      "type": "string"
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "components"],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "components": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "LuaScript": {
                "type": "object",
                "properties": {
                  "module": { "type": "string", "pattern": "^script://" },
                  "properties": { "type": "object" }
                }
              },
              "Rigidbody2D": {
                "type": "object"
              },
              "BoxCollider2D": {
                "type": "object",
                "properties": {
                  "layer": { "type": "string" }
                }
              },
              "AudioSource": {
                "type": "object",
                "properties": {
                  "clip": { "type": "string", "pattern": "^asset://" },
                  "play_on_start": { "type": "boolean" },
                  "loop": { "type": "boolean" },
                  "volume": { "type": "number", "minimum": 0, "maximum": 1 }
                }
              },
              "AudioListener": {
                "type": "object",
                "properties": {
                  "primary": { "type": "boolean" }
                }
              },
              "VideoPlayer": {
                "type": "object",
                "properties": {
                  "clip": { "type": "string", "pattern": "^asset://" },
                  "play_on_start": { "type": "boolean" },
                  "loop": { "type": "boolean" }
                }
              }
            }
          }
        }
      }
    },
    "elements": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "id": { "type": "string" },
          "action": { "type": "string" }
        }
      }
    }
  }
}
