{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://demiengine.local/schemas/scene.schema.json",
  "title": "DemiEngine Scene",
  "type": "object",
  "required": [
    "format_version",
    "id",
    "entities"
  ],
  "additionalProperties": true,
  "properties": {
    "format_version": {
      "type": "integer",
      "minimum": 1
    },
    "id": {
      "type": "string",
      "pattern": "^scene://"
    },
    "name": {
      "type": "string"
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "components"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "components": {
            "$ref": "components.schema.json"
          }
        }
      }
    },
    "instances": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "prefab"],
        "properties": {
          "id": { "type": "string" },
          "prefab": { "type": "string", "pattern": "^prefab://" },
          "overrides": { "type": "object" }
        }
      }
    },
    "elements": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "action": {
            "type": "string"
          },
          "scale": {
            "type": "number"
          },
          "font_size": {
            "type": "number",
            "minimum": 0
          }
        }
      }
    }
  }
}
