{
  "format_version": 1,
  "name": "Minimal 2D Android",
  "main_scene": "scene://minimal_2d_android/menu",
  "scenes": [
    {
      "id": "scene://minimal_2d_android/menu",
      "path": "scenes/menu.scene.json"
    },
    {
      "id": "scene://minimal_2d_android/platformer",
      "path": "scenes/platformer.scene.json"
    },
    {
      "id": "scene://minimal_2d_android/spiral",
      "path": "scenes/spiral.scene.json"
    }
  ],
  "input": {
    "actions": {
      "move": [
        {"input": "a", "scale": -1},
        {"input": "left", "scale": -1},
        {"input": "d", "scale": 1},
        {"input": "right", "scale": 1}
      ],
      "jump": ["space", "w", "up"]
    }
  },
  "scripting": {
    "language": "lua54",
    "modules": [
      "main_menu",
      "menu.actions",
      "menu.network",
      "network_lobby",
      "network_replication",
      "player_colors"
    ]
  }
}
