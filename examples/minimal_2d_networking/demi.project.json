{
  "format_version": 1,
  "name": "Minimal 2D Networking",
  "main_scene": "scene://minimal_2d_networking/menu",
  "scenes": [
    {
      "id": "scene://minimal_2d_networking/menu",
      "path": "scenes/menu.scene.json"
    },
    {
      "id": "scene://minimal_2d_networking/platformer",
      "path": "scenes/platformer.scene.json"
    },
    {
      "id": "scene://minimal_2d_networking/spiral",
      "path": "scenes/spiral.scene.json"
    }
  ],
  "input": {
    "actions": {
      "move": [
        {"input": "a", "scale": -1},
        {"input": "left", "scale": -1},
        {"input": "d", "scale": 1},
        {"input": "right", "scale": 1}
      ],
      "jump": ["space", "w", "up"]
    }
  },
  "physics": {
    "layers": {
      "collectibles": ["player"],
      "network": ["platform", "player"],
      "platform": ["network", "player"],
      "player": ["collectibles", "network", "platform"]
    }
  },
  "scripting": {
    "language": "lua54",
    "modules": [
      "main_menu",
      "menu.actions"
    ]
  }
}
